{
    "name": "drupal-composer/drupal-project",
    "description": "Project template for Drupal 8 projects with composer",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "",
            "role": ""
        }
    ],
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        },
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        },
        {
            "type": "package",
            "package": {
                "name": "mozilla/pdf.js",
                "version": "1.10.100",
                "type": "drupal-library",
                "extra": {
                    "installer-name": "pdf.js"
                },
                "dist": {
                    "type": "zip",
                    "url": "https://github.com/mozilla/pdf.js/releases/download/v1.10.100/pdfjs-1.10.100-dist.zip"
                }
            }
        }

    ],
    "require": {
        "php": ">=7.0.8",
        "adubovskoy/phpquery": "^1.0",
        "composer/installers": "^1.2",
        "cweagans/composer-patches": "^1.6",
        "drupal-composer/drupal-scaffold": "^2.5",
        "drupal/admin_toolbar": "^2.0",
        "drupal/adminimal_admin_toolbar": "^1.10",
        "drupal/amswap": "^2.0@beta",
        "drupal/audiofield": "^1.9",
        "drupal/backup_migrate": "^4.0",
        "drupal/better_exposed_filters": "^4.0@alpha",
        "drupal/block_content_permissions": "^1.8",
        "drupal/captcha": "^1.0@beta",
        "drupal/coffee": "^1.0@beta",
        "drupal/console": "^1.0.2",
        "drupal/core": "^8.7.0",
        "drupal/delete_all": "^1.2",
        "drupal/devel": "^2.1",
        "drupal/devel_php": "^1.1",
        "drupal/diff": "^1.0",
        "drupal/domain_theme_switch": "^1.4",
        "drupal/draggableviews": "^1.2",
        "drupal/easy_breadcrumb": "^1.12",
        "drupal/entity_browser": "^2.2",
        "drupal/field_group": "~3.0",
        "drupal/filefield_sources": "^1.0@alpha",
        "drupal/form_mode_manager": "^1.3",
        "drupal/google_analytics": "2.4",
        "drupal/hide_revision_field": "^2.1",
        "drupal/imagemagick": "^2.6",
        "drupal/inline_entity_form": "^1.0@RC",
        "drupal/link_attributes": "^1.9",
        "drupal/mailchimp": "^1.11",
        "drupal/memcache": "^2.0",
        "drupal/metatag": "^1.11",
        "drupal/migrate_source_csv": "^3.1",
        "drupal/migrate_tools": "^4.4",
        "drupal/migration_tools": "^2.1",
        "drupal/override_node_options": "^2.4",
        "drupal/paragraphs": "^1.10",
        "drupal/paragraphs_edit": "^2.0@alpha",
        "drupal/pathauto": "^1.5",
        "drupal/pdf": "1.x-dev",
        "drupal/queue_ui": "^2.0",
        "drupal/readonly_field_widget": "^1.3",
        "drupal/recaptcha": "^2.5",
        "drupal/redirect": "^1.4",
        "drupal/redirect_after_login": "^2.5",
        "drupal/search_api_page": "^1.0@beta",
        "drupal/search_file_attachments": "^1.1",
        "drupal/select2": "^1.5",
        "drupal/sharethis": "^2.0@beta",
        "drupal/simple_sitemap": "^3.5",
        "drupal/smtp": "^1.0@beta",
        "drupal/taxonomy_multidelete_terms": "^1.1",
        "drupal/time_field": "^1.13",
        "drupal/token": "^1.5",
        "drupal/toolbar_menu": "^2.1",
        "drupal/toolbar_menu_clean": "^1.2",
        "drupal/video_embed_field": "^2.2",
        "drupal/view_unpublished": "^1.0@alpha",
        "drupal/views_bulk_edit": "^2.4",
        "drupal/views_bulk_operations": "^3.3",
        "drupal/views_data_export": "^1.0@beta",
        "drupal/webform": "^5.5",
        "drupal/webform_mailchimp": "^5.8",
        "drush/drush": "^9.0.0",
        "mozilla/pdf.js": "^1.10",
        "npm-asset/select2": "^4.0",
        "oomphinc/composer-installers-extender": "^1.1",
        "pguardiario/phpuri": "^1.0",
        "querypath/querypath": "dev-master",
        "vlucas/phpdotenv": "^2.4",
        "webflo/drupal-finder": "^1.0.0",
        "webmozart/path-util": "^2.3",
        "zaporylie/composer-drupal-optimizations": "^1.0",
        "zendframework/zend-filter": "^2.9"
    },
    "require-dev": {
        "webflo/drupal-core-require-dev": "^8.7.0"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "autoload": {
        "classmap": [
            "scripts/composer/ScriptHandler.php"
        ],
        "files": ["load.environment.php"]
    },
    "scripts": {
        "pre-install-cmd": [
            "DrupalProject\\composer\\ScriptHandler::checkComposerVersion"
        ],
        "pre-update-cmd": [
            "DrupalProject\\composer\\ScriptHandler::checkComposerVersion"
        ],
        "post-install-cmd": [
            "DrupalProject\\composer\\ScriptHandler::createRequiredFiles"
        ],
        "post-update-cmd": [
            "DrupalProject\\composer\\ScriptHandler::createRequiredFiles"
        ]
    },
    "extra": {
        "installer-types": ["bower-asset", "npm-asset"],
        "composer-exit-on-patch-failure": true,
        "patchLevel": {
            "drupal/core": "-p2"
        },
        "installer-paths": {
            "web/core": ["type:drupal-core"],
            "web/libraries/{$name}": [
                "type:drupal-library",
                "type:bower-asset",
                "type:npm-asset"
            ],
            "web/modules/contrib/{$name}": ["type:drupal-module"],
            "web/profiles/contrib/{$name}": ["type:drupal-profile"],
            "web/themes/contrib/{$name}": ["type:drupal-theme"],
            "drush/Commands/contrib/{$name}": ["type:drupal-drush"]
        },
        "drupal-scaffold": {
            "initial": {
                ".editorconfig": "../.editorconfig",
                ".gitattributes": "../.gitattributes"
            }
        },
        "patches": {
            "drupal/sharethis": {
                "https://www.drupal.org/project/sharethis/issues/2885710": "https://www.drupal.org/files/issues/Error-operator-not-supported-for-strings-2885710-12128018.patch",
                "https://www.drupal.org/project/sharethis/issues/2816573": "https://www.drupal.org/files/issues/2816573-6.patch"
            },
            "drupal/webform_mailchimp": {
                "https://www.drupal.org/project/webform_mailchimp/issues/3036323": "https://www.drupal.org/files/issues/2019-10-05/3036323-interest-groups-predefined-options-15.patch"
            },
            "drupal/webform": {
                "https://www.drupal.org/project/webform/issues/2859421": "https://www.drupal.org/files/issues/2019-10-11/webform-2859421-5.patch"
            },
            "drupal/paragraphs_edit": {
                "https://www.drupal.org/project/paragraphs_edit/issues/2944653": "https://www.drupal.org/files/issues/2019-03-22/error_on_missing_parent-2944653-13034993.patch"
            }
        }
    }
}
