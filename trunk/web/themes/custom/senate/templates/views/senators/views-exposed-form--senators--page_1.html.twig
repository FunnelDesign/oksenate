{#
/**
 * @file
 * Default theme implementation of a views exposed form.
 *
 * Available variables:
 * - form: A render element representing the form.
 *
 * @see template_preprocess_views_exposed_form()
 *
 * @ingroup themeable
 */
#}
{% if q is not empty %}
    {#
      This ensures that, if clean URLs are off, the 'q' is added first,
      as a hidden form element, so that it shows up first in the POST URL.
    #}
    {{ q }}
{% endif %}
<div class="sSen__fil">
    <div class="sSen__filCol">
        <div class="sSen__filIco">
            <img src="{{ theme_path }}/dist/images/filterIco/senator-filter-icons-5.png" srcset="{{ theme_path }}/dist/images/filterIco/senator-filter-icons-5-2x.png 2x"  alt="">
        </div>
        {{ form.party }}
    </div>
    <div class="sSen__filCol">
        <div class="sSen__filIco">
            <img src="{{ theme_path }}/dist/images/filterIco/senator-filter-icons-4.png" srcset="{{ theme_path }}/dist/images/filterIco/senator-filter-icons-4-2x.png 2x"  alt="">
        </div>
        {{ form.committee }}
    </div>
</div>
