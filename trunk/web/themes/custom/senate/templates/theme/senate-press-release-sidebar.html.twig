{#
/**
 * @file
 * News sidebar.
 *
 */
#}
<div class="bSort">
  <h4>{{ 'Sort By Date'|t }}</h4>

  <div class="bHide bHide_a">
    <div class="bHide__cont">
      <div class="bSort__items">
        {% if archive %}
          {% for year, months in archive %}
            <div class="bSort__item">
              <button type="button" class="bSort__title">
                {{ year }}
              </button>
              <div class="bSort__body">
                {% for month_name, data in months %}
                  {% if is_audio %}
                    {% set url = '/audio/' ~ year ~ '-' ~ data.month_digits %}
                  {% elseif senator_nid %}
                    {% set url = '/senator-press-releases/' ~ senator_nid ~ '/' ~ year ~ '-' ~ data.month_digits %}
                  {% else %}
                    {% set url = '/press-releases/' ~ year ~ '-' ~ data.month_digits %}
                  {% endif %}
                  {% set month_class = (current_path == url) ? 'bef-link-active' : '' %}
                  <a href="{{ url }}" class="{{ month_class }}">{{ month_name }}</a>
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>
    <div class="bHide__moreWr">
      <button type="button" class="bHide__more" data-ev="toggleClass:bHide:open" aria-label="{{ "Toggle show more content" |t}}">
        <span class="bHide__moreOpen">{{ 'show more'|t }}</span>
        <span class="bHide__moreClose">{{ 'show less'|t }}</span>
      </button>
    </div>
  </div>
</div>
