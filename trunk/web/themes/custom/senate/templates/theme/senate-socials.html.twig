{#
/**
 * @file
 * Socials and Print.
 *
 */
#}
<div class="bShare section__bShare {{ wrapper_class }}">
  {% if socials %}
    <div class="bShare__bSoc">
      <div class="bShare__title not-selectable">
        {{ 'Share'|t }}
      </div>
      <div class="bSoc bSoc_min bSoc_min_share {{ icons_class }}">

        <div class="bSoc__items sharethis-wrapper">
          {% for social in socials %}
            <div class="bSoc__item">
              <button st_url="{{ url }}" st_title="{{ title }}" class="bSoc__ico ss-icon ss-social-circle {{ social }}"></button>
            </div>
          {% endfor %}
        </div>

      </div>
    </div>
  {% endif %}

  {% if printer %}
    <div class="bShare__print not-selectable">
      <a href="javascript:window.print()">
        <i class="ss-icon ss-glyphish-outlined ss-print"></i>
        {{ "Printer Friendly"|t }}
      </a>
    </div>
  {% endif %}
</div>
