function _senate_get_archive_week_review() {
  $query = \Drupal::database()->select('node_field_data', 'nfd')
    ->condition('nfd.type', 'week_review')
    ->condition('nfd.status', 1);
  $query->innerJoin('node__field_week_review_date', 'rd', 'rd.entity_id = nfd.nid AND rd.deleted = 0 AND rd.bundle = \'week_review\'');

  $query->addExpression("DATE_FORMAT(field_week_review_date_value, '%M')", 'month');
  $query->addExpression("DATE_FORMAT(field_week_review_date_value, '%m')", 'month_digits');
  $query->addExpression("DATE_FORMAT(field_week_review_date_value, '%Y')", 'year');

  $query->groupBy('year');
  $query->groupBy('month_digits');
  $query->groupBy('month');
  $query->orderBy('year', 'desc');
  $query->orderBy('month_digits', 'desc');

  $result = $query->execute()->fetchAll();

  $archive = [];
  foreach ($result as $row) {
    $archive[$row->year][$row->month] = $row;
  }

  return !empty($archive) ? $archive : [];
}

function _senate_get_archive_press_releases_review($only_with_audio = FALSE, $senator_nid = FALSE) {
  $query = \Drupal::database()->select('node_field_data', 'nfd')
    ->condition('nfd.type', 'press_release')
    ->condition('nfd.status', 1);
  $query->innerJoin('node__field_date', 'rd', 'rd.entity_id = nfd.nid AND rd.deleted = 0 AND rd.bundle = \'press_release\'');

  $query->addExpression("DATE_FORMAT(field_date_value, '%M')", 'month');
  $query->addExpression("DATE_FORMAT(field_date_value, '%m')", 'month_digits');
  $query->addExpression("DATE_FORMAT(field_date_value, '%Y')", 'year');

  if($only_with_audio) {
    $query->innerJoin('node__field_press_release_audio', 'audio', 'nfd.nid= audio.entity_id');
  } else {
    $query->leftJoin('node_revision__field_press_release_type', 'pst', 'nfd.nid=pst.entity_id');
    $query->isNull('pst.field_press_release_type_value');
  }
  if (!empty($senator_nid)) {
    $query->innerJoin('node__field_senator', 'senator', 'nfd.nid = senator.entity_id AND senator.field_senator_target_id = ' . $senator_nid);
  }

  $query->groupBy('year');
  $query->groupBy('month_digits');
  $query->groupBy('month');
  $query->orderBy('year', 'desc');
  $query->orderBy('month_digits', 'desc');

  $result = $query->execute()->fetchAll();
//  $a = $query->__toString();

  $archive = [];
  foreach ($result as $row) {
    $archive[$row->year][$row->month] = $row;
  }

  return !empty($archive) ? $archive : [];
}

function _senate_get_session_summary_years() {
  $query = \Drupal::database()->select('node_field_data', 'nfd')
    ->condition('nfd.type', 'session_summary')
    ->condition('nfd.status', 1);
  $query->innerJoin('node__field_session_summary_year_date', 'rd', 'rd.entity_id = nfd.nid AND rd.deleted = 0 AND rd.bundle = \'session_summary\'');
  $query->addExpression("DATE_FORMAT(field_session_summary_year_date_value, '%Y')", 'year');
  $query->orderBy('year', 'desc');
  $result = $query->execute()->fetchAll();

  $archive = [];
  $archive[0] = 'Select a year';
  foreach ($result as $row) {
    $archive[] = $row->year;
  }

  return !empty($archive) ? $archive : [];
}

function _senate_get_journals_options() {
  $query = \Drupal::database()->select('paragraphs_item_field_data', 'pifd')
    ->condition('pifd.type', 'journals_files')
    ->condition('pifd.status', 1);
  $query->innerJoin('node__field_journals_files', 'nfjf', 'pifd.id = nfjf.field_journals_files_target_id AND nfjf.deleted = 0');
  $query->innerJoin('node_field_data', 'nfd', 'nfjf.entity_id = nfd.nid AND nfd.status = 1 AND nfd.type = \'journals\'');
  $query->innerJoin('paragraph__field_journals_files_date', 'pfjfd', 'pifd.id = pfjfd.entity_id AND pfjfd.deleted = 0');

  $query->addExpression("DATE_FORMAT(field_journals_files_date_value, '%M')", 'month');
  $query->addExpression("DATE_FORMAT(field_journals_files_date_value, '%m')", 'month_digits');
  $query->addExpression("DATE_FORMAT(field_journals_files_date_value, '%Y')", 'year');
  $query->addExpression("DATE_FORMAT(field_journals_files_date_value, '%d')", 'day');

  $query->groupBy('year');
  $query->groupBy('month_digits');
  $query->groupBy('month');
  $query->groupBy('day');
  $query->orderBy('year', 'desc');
  $query->orderBy('month_digits', 'asc');
  $query->orderBy('day', 'asc');

  $result = $query->execute()->fetchAll();

  $options = [];
  foreach ($result as $row) {
//    $options[$row->year][$row->month_digits] = $row->month;
    $options['options'][$row->year][$row->month_digits]['month'] = $row->month;
    $options['options'][$row->year][$row->month_digits]['days'][$row->day] = (int)$row->day;
    $options['dates'][] = $row->month_digits . "/" . $row->day . "/" . $row->year;
  }

  return !empty($options) ? $options : [];
}

function _senate_votes_get_grouped_items($pr_ids) {
  $query = \Drupal::database()->select('paragraph__field_senate_votes_measure', 'pfsvm')
    ->fields('pfsvm', ['entity_id', 'field_senate_votes_measure_value'])
    ->condition('pfsvm.bundle', 'senate_votes')
    ->condition('pfsvm.deleted', 0)
    ->condition('pfsvm.entity_id', $pr_ids, 'IN')
    ->orderBy('field_senate_votes_measure_value', 'ASC');
  $result = $query->execute()->fetchAll();

  $grouped = [];
  foreach ($result as $row) {
    $grouped[$row->field_senate_votes_measure_value][] = $row->entity_id;
  }

  return !empty($grouped) ? $grouped : [];
}

/**
 * Implements hook_preprocess_views_view_field().
 */
function senate_preprocess_views_view_field(&$vars) {
  $view = $vars['view'];
  $id = $view->id();
  $display_id = $view->current_display;

  switch ($id) {
    case 'search_statutes_constitutions':
      $items = $vars['field']->getItems($vars["row"]);
      if (!empty($items) && !empty($items[0])) {
        $options = ['class' => ['bListLinks__link']];
        $options['target'] = '_blank';
        $items[0]["rendered"]["#url"]->setOption('attributes', $options);

        $parent_node = !empty($vars["row"]->_relationship_entities) &&
          !empty($vars["row"]->_relationship_entities["reverse_field_statutes_constit_files_node"]) ?
          $vars["row"]->_relationship_entities["reverse_field_statutes_constit_files_node"] : '';
        $fid = !empty($vars["row"]->fid) ? $vars["row"]->fid : '';
        $files = !empty($parent_node) ? $parent_node->field_statutes_constit_files->getValue() : [];
        foreach ($files as $file) {
          if (!empty($file["target_id"]) && ($file["target_id"] == $fid)) {
            $file_name = !empty($items[0]["rendered"]["#title"]) ? pathinfo($items[0]["rendered"]["#title"]) : '';
            $file_name = !empty($file_name['filename']) ? $file_name['filename'] : '';
            $file_name = !empty($file["description"]) ? $file["description"] : $file_name;
            $items[0]["rendered"]["#title"] = $file_name;
          }
        }
        $vars["output"] = $items[0]["rendered"];
      }
      break;
    case 'senate_votes_inner':
      $field_name = !empty($vars['field']) ? $vars['field']->field : '';
      $paragraph = !empty($vars["row"]) && !empty($vars["row"]->_entity) ? $vars["row"]->_entity : '';

      if (!empty($paragraph)) {
        if ($field_name == 'field_senate_votes_measure') {
          $measure = $paragraph->hasField('field_senate_votes_measure') ?
            $paragraph->get('field_senate_votes_measure') : '';
          $measure = !empty($measure) && !empty($measure->get(0)) ? $measure->get(0)->value : '';

          $measure_link = $paragraph->hasField('field_senate_votes_measure_link') ?
            $paragraph->get('field_senate_votes_measure_link') : '';
          $measure_link = !empty($measure_link) && !empty($measure_link->get(0)) ?
            $measure_link->get(0)->uri : '';

          if (!empty($measure) && !empty($measure_link)) {
            $url = Url::fromUri($measure_link);

            $attributes['target'] = '_blank';
            $url->setOption('attributes', $attributes);
            $vars["output"] = Link::fromTextAndUrl($measure, $url)->toString();
          }
        }
        else if ($field_name == 'field_senate_votes_author') {
          $author = $paragraph->hasField('field_senate_votes_author') ?
            $paragraph->get('field_senate_votes_author') : '';
          $author = !empty($author) && !empty($author->get(0)) ? $author->get(0)->value : '';

          $author_link = $paragraph->hasField('field_senate_votes_author_link') ?
            $paragraph->get('field_senate_votes_author_link') : '';
          $author_link = !empty($author_link) && !empty($author_link->get(0)) ?
            $author_link->get(0)->uri : '';

          if (!empty($author) && !empty($author_link)) {
            $url = Url::fromUri($author_link);

            $attributes['target'] = '_blank';
            $url->setOption('attributes', $attributes);
            $vars["output"] = Link::fromTextAndUrl($author, $url)->toString();
          }
        }
        else if ($field_name == 'field_senate_votes_action_link') {
          $url = $paragraph->hasField('field_senate_votes_action_link') ?
            $paragraph->get('field_senate_votes_action_link') : '';
          $link = !empty($url) && !empty($url->get(0)) ? $url->get(0)->uri : '';
          $title = !empty($url) && !empty($url->get(0)) ? $url->get(0)->title : '';

          if (!empty($link) && !empty($title)) {
            $url = Url::fromUri($link);

            $attributes['target'] = '_blank';
            $attributes['class'] = ['bTb__text', 'bTb__text_a',];
            $url->setOption('attributes', $attributes);
            $vars["output"] = Link::fromTextAndUrl($title, $url)->toString();
          }
        }
        else if ($field_name == 'field_senate_votes_action_file') {
          $file = $paragraph->hasField('field_senate_votes_action_file') ?
            $paragraph->get('field_senate_votes_action_file') : '';
          $description = !empty($file) && !empty($file->get(0)) ? $file->get(0)->description : '';
          $fid = !empty($file) && !empty($file->get(0)) ? $file->get(0)->target_id : '';
          $file = !empty($fid) ? \Drupal\file\Entity\File::load($fid) : '';

          if (!empty($file)) {
            $url = $file->createFileUrl(FALSE);
            $url = Url::fromUri($url);
            $options = ['class' => ['bTb__text', 'bTb__text_a',]];
            $options['target'] = '_blank';

            $url->setOption('attributes', $options);
            $vars['output'] = Link::fromTextAndUrl($description, $url);
          }
        }
      }
      break;
  }
}

function _senate_get_staff_options() {
  $query = \Drupal::database()->select('paragraphs_item_field_data', 'pifd')
    ->condition('pifd.type', 'staff')
    ->condition('pifd.status', 1);
  $query->innerJoin('node__field_staff', 'nfs', 'pifd.id = nfs.field_staff_target_id AND nfs.deleted = 0');
  $query->innerJoin('node_field_data', 'nfd', 'nfs.entity_id = nfd.nid AND nfd.status = 1 AND nfd.type = \'staff\'');
  $query->innerJoin('paragraph__field_staff_division', 'pfsd', 'pifd.id = pfsd.entity_id AND pfsd.deleted = 0');
  $query->fields('pfsd', ['field_staff_division_value']);

  $query->orderBy('field_staff_division_value', 'asc')->distinct();

  $result = $query->execute()->fetchCol();

  return !empty($result) ? $result : [];
}

/**
 * Used issue type terms
 * @param $tid
 *
 * @return array
 */
function _senate_get_issue_type_terms() {
  $query = \Drupal::database()->select('node_field_data', 'nfd')
    ->condition('nfd.type', 'issue')
    ->condition('nfd.status', 1);
  $query->innerJoin('node__field_issue_type_term', 'rd', 'rd.entity_id = nfd.nid AND rd.deleted = 0 AND rd.bundle = \'issue\'');
  $query->addExpression("field_issue_type_term_target_id", 'term');
  $query->orderBy('field_issue_type_term_target_id', 'asc')->distinct();

  $result = $query->execute()->fetchAll();

  $archive = [];
  $used_tids = [];
  foreach ($result as $key => $row) {
    $term_obj = Drupal::entityTypeManager()
      ->getStorage('taxonomy_term')
      ->load($row->term);
    $term_name = $term_obj->getName();
    if (!in_array($term_name, $used_tids)) {
      $archive[$key]['term_name'] = $term_name;
      $archive[$key]['term_id'] = strtolower(preg_replace('/[^a-zA-Z0-9-]+/', '-', $term_name));;
      $used_tids[] = $term_name;
    }
  }
  array_unshift($archive, ['term_name' => 'Select a paper', 'term_id' => '']);
  return !empty($archive) ? $archive : [];
}

function senate_preprocess_views_view_grouping(&$vars) {
  $view = $vars['view'];
  if ($view->id() == 'issue_papers') {
    $vars['id'] = strtolower(preg_replace('/[^a-zA-Z0-9-]+/', '-', $vars['title']));
  }
}

/**
 * Get socials.
 * @param $entity
 * @param $entity_type
 * @param string $url
 * @param string $title
 * @param string $color
 *
 * @return array
 */
function _senate_get_socials($entity, $entity_type, $url = '', $title = '', $color = '') {
  $sharethis_manager = \Drupal::service('sharethis.manager');
  $st_js = $sharethis_manager->sharethisIncludeJs();

  $socials = [
    '#theme' => 'senate_socials',
    '#entity' => $entity,
    '#entity_type' => $entity_type,
    '#url' => $url,
    '#title' => $title,
    '#printer' => TRUE,
    '#color' => $color,
    '#attached' => [
      'library' => [
        'sharethis/sharethispickerexternalbuttonsws',
        'sharethis/sharethispickerexternalbuttons',
        'sharethis/sharethis',
      ],
      'drupalSettings' => [
        'sharethis' => $st_js,
      ],
    ],
  ];

  return $socials;
}

/**
 * Implements hook_preprocess_HOOK().
 * @param $vars
 */
function senate_preprocess_senate_socials(&$vars) {
  $entity = !empty($vars["entity"]) ? $vars["entity"] : '';
  $entity_type = !empty($vars["entity_type"]) ? $vars["entity_type"] : '';

  $social_class = [
    'fb' => 'ss-facebook st_facebook_custom',
    'tw' => 'ss-twitter st_twitter_custom',
    'email' => 'ss-mail st_email_custom',
  ];

  $color = !empty($color) ? $color : 'white';

  if (!empty($entity) && ($entity_type == 'node')) {
    switch ($entity->bundle()) {
      case 'press_release':
      case 'contact':
      case 'edu_indiv_art_work':
      case 'issue':
      case 'privacy_policy':
      case 'senate_votes':
      case 'senator':
      case 'tables_page':
      case 'week_review':
      case 'protem_podcast':
      case 'senator_blog_post':
      case 'simple_page':
        $color = 'navy';
        break;
    }
  }
  elseif (!empty($entity) && ($entity_type == 'view')) {
    switch ($entity->id()) {
      case 'subcommittee_events':
      case 'agencies_documents':
        $color = 'navy';
        break;
    }
  }

  $vars['socials'] = $social_class;
  $vars['color'] = $color;
  if ($color == 'white') {
    $vars['wrapper_class'] = '';
    $vars['icons_class'] = 'bSoc_cl_a';
  }
  elseif ($color == 'navy') {
    $vars['wrapper_class'] = 'bShare_cl_a';
    $vars['icons_class'] = 'bSoc_cl_b';
  }

  if (empty($vars["url"])) {
    $vars["url"] = Url::fromRoute('<current>', [], ['query' => \Drupal::request()->query->all(), 'absolute' => 'true'])->toString();
  }
  if (empty($vars["title"])) {
    $request = \Drupal::request();
    if ($route = $request->attributes->get(\Symfony\Cmf\Component\Routing\RouteObjectInterface::ROUTE_OBJECT)) {
      $vars["title"] = \Drupal::service('title_resolver')->getTitle($request, $route);
      $vars["title"] = strip_tags($vars["title"]);
    }
  }
  else {
    $vars["title"] = strip_tags($vars["title"]);
  }
}

/**
 * Captcha pre_render.
 */
function senate_change_captcha_description($element) {
  $description = !empty($element["captcha_widgets"]) &&
    !empty($element["captcha_widgets"]["captcha_response"]) &&
    !empty($element["captcha_widgets"]["captcha_response"]["#description"]) ?
    $element["captcha_widgets"]["captcha_response"]["#description"] : '';
  $add_description = t('Math question not to test basic math skills.');
  $title = !empty($element["captcha_widgets"]) && !empty($element["captcha_widgets"]["captcha_response"]) &&
    !empty($element["captcha_widgets"]["captcha_response"]["#title"]) ?
    $element["captcha_widgets"]["captcha_response"]["#title"] : '';
  $add_title = t('CAPTCHA:');

  if (!empty($description)) {
    $desc = is_object($description) ? $description->__toString() : $description;
    $add_desc = $add_description->__toString();

    $has_add_desc = (strpos($desc, $add_desc) !== FALSE);
    if (!$has_add_desc) {
      $element["captcha_widgets"]["captcha_response"]["#description"] = $description . ' ' . $add_description;
    }
  }

  if (!empty($title)) {
    $title = is_object($title) ? $title->__toString() : $title;
    $add_title = $add_title->__toString();

    $has_add_title = (strpos($title, $add_title) !== FALSE);
    if (!$has_add_title) {
      $element["captcha_widgets"]["captcha_response"]["#title"] = $add_title . ' ' . $title;
    }
  }

  return $element;
}

/**
 * Get node created user.
 * @param $uid
 *
 * @return array
 */
function _senate_get_senators_name($uid) {
  if (empty($uid)) {
    return [];
  }

  $query = \Drupal::database()->select('node_field_data', 'nfd')
    ->fields('nfd', ['nid', 'title'])
    ->condition('nfd.uid', $uid)
    ->condition('nfd.type', 'senator')
    ->condition('nfd.status', 1);

  $result = $query->execute()->fetchAllKeyed();

  return !empty($result) ? $result : [];
}

function _senate_get_archive_senator_blog_post($uid) {
  if (empty($uid)) {
    return [];
  }

  $query = \Drupal::database()->select('node_field_data', 'nfd')
    ->condition('nfd.type', 'senator_blog_post')
    ->condition('nfd.status', 1)
    ->condition('nfd.uid', $uid);
  $query->innerJoin('node__field_senator_blog_post_posted', 'rd', 'rd.entity_id = nfd.nid AND rd.deleted = 0 AND rd.bundle = \'senator_blog_post\'');

  $query->addExpression("DATE_FORMAT(field_senator_blog_post_posted_value, '%M')", 'month');
  $query->addExpression("DATE_FORMAT(field_senator_blog_post_posted_value, '%m')", 'month_digits');
  $query->addExpression("DATE_FORMAT(field_senator_blog_post_posted_value, '%Y')", 'year');

  $query->groupBy('year');
  $query->groupBy('month_digits');
  $query->groupBy('month');
  $query->orderBy('year', 'desc');
  $query->orderBy('month_digits', 'desc');

  $result = $query->execute()->fetchAll();
  //  $a = $query->__toString();

  $archive = [];
  foreach ($result as $row) {
    $archive[$row->year][$row->month] = $row;
  }

  return !empty($archive) ? $archive : [];
}

/**
 * Implements hook_theme_suggestions_node_alter().
 */
function senate_theme_suggestions_block_alter(array &$suggestions, array $vars) {
  $webform = (!empty($vars["elements"]) && !empty($vars["elements"]["content"]["#webform"])) ?
    $vars["elements"]["content"]["#webform"] : '';

  if (!empty($webform)) {
    $suggestions[] = 'block__webform__' . $webform->id();
  }
}

/**
 * Sign up committee meeting validation.
 * @param $form
 * @param \Drupal\Core\Form\FormStateInterface $form_state
 */
function webform_sign_up_committee_meeting_validate($form, FormStateInterface $form_state) {
  $input = $form_state->getUserInput();
  $committees = !empty($input["committees"]) ? $input["committees"] : [];
  if (!empty($committees['all'])) {
    unset($committees['all']);
    $committees_keys = array_keys($committees);
    $form_state->setValue('committees', $committees_keys);
  }
}

function _senate_get_votes_measure_options($nid) {
  if (empty($nid)) {
    return;
  }

  $query = \Drupal::database()->select('paragraphs_item_field_data', 'pifd')
    ->condition('pifd.type', 'senate_votes')
    ->condition('pifd.status', 1);
  $query->innerJoin('node__field_senate_votes', 'nfsv', 'pifd.id = nfsv.field_senate_votes_target_id AND nfsv.deleted = 0');
  $query->innerJoin('node_field_data', 'nfd', 'nfsv.entity_id = nfd.nid AND nfd.status = 1 AND nfd.type = \'senate_votes\'');
  $query->innerJoin('paragraph__field_senate_votes_measure', 'pfsvm', 'pifd.id = pfsvm.entity_id AND pfsvm.deleted = 0');
  $query->fields('pfsvm', ['field_senate_votes_measure_value']);
  $query->condition('nfd.nid', $nid);

  $query->orderBy('field_senate_votes_measure_value', 'asc')->distinct();

  $result = $query->execute()->fetchCol();

  return !empty($result) ? $result : [];
}

function _senate_get_votes_author_options($nid) {
  if (empty($nid)) {
    return;
  }

  $query = \Drupal::database()->select('paragraphs_item_field_data', 'pifd')
    ->condition('pifd.type', 'senate_votes')
    ->condition('pifd.status', 1);
  $query->innerJoin('node__field_senate_votes', 'nfsv', 'pifd.id = nfsv.field_senate_votes_target_id AND nfsv.deleted = 0');
  $query->innerJoin('node_field_data', 'nfd', 'nfsv.entity_id = nfd.nid AND nfd.status = 1 AND nfd.type = \'senate_votes\'');
  $query->innerJoin('paragraph__field_senate_votes_author', 'pfsva', 'pifd.id = pfsva.entity_id AND pfsva.deleted = 0');
  $query->fields('pfsva', ['field_senate_votes_author_value']);
  $query->condition('nfd.nid', $nid);

  $query->orderBy('field_senate_votes_author_value', 'asc')->distinct();

  $result = $query->execute()->fetchCol();

  return !empty($result) ? $result : [];
}

function _senate_get_journals_month_options($year) {
  $month_option = [];
  $year = !empty($year) && is_array($year) ? $year : [];

  foreach ($year as $key => $value) {
    if (!empty($value['month'])) {
      $month_option[$key] = $value['month'];
    }
  }

  return $month_option;
}
