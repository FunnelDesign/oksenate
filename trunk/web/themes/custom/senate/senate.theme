/**
 * Implements hook_preprocess_views_view_list();
 */
function senate_preprocess_views_view_list(&$vars) {
  $view = $vars['view'];
  $id = $view->id();
  $display_id = $view->current_display;

  switch ($id) {
    case 'committee_dropdown':
      $args = !empty($view->args) ? $view->args[0] : '';
      $vars['empty_title'] = t('Select Committee');
      if (!empty($args)) {
        $args = explode(',', $args);
        $ancestors = \Drupal::service('entity_type.manager')
          ->getStorage("taxonomy_term")->loadParents($args[0]);
        if (!empty($ancestors)) {
          $vars['empty_title'] = t('Select Subcommittee');
        }
      }
      break;
  }
}

/**
 * Implements hook_preprocess_views_view_unformatted();
 */
function senate_preprocess_views_view_unformatted(&$vars) {
  $view = $vars['view'];
  $id = $view->id();
  $display_id = $view->current_display;

  switch ($id) {
    case 'subcommittee_agencies':
      $rows = !empty($vars["rows"]) ? $vars["rows"] : [];
      $vars['unique_items'] = [];
      $vars['agency_doc_path'] = SENATE_AGENCIES_DOC_BASE_PATH;
      $current_path = \Drupal::service('path.current')->getPath();
      $path_args = explode('/', $current_path);
      $arg_0 = !empty($path_args[1]) ? $path_args[1] : '';
      $arg_1 = !empty($path_args[2]) ? $path_args[2] : '';
      if (($arg_0 == 'node') && is_numeric($arg_1)) {
        $alias = \Drupal::service('path.alias_manager')->getAliasByPath($current_path);
        $alias_args = explode('/', $alias);
        $last = array_pop($alias_args);
        if (!empty($last)) {
          $vars['agency_doc_path'] = str_replace('/education/', '/' . $last . '/', $vars['agency_doc_path']);
        }
      }

      foreach ($rows as $key => $row) {
        $tid = (!empty($row["content"]) && !empty($row["content"]["#row"])) ?
          $row["content"]["#row"]->tid : '';
        if (!in_array($tid, $vars['unique_items'])) {
          $vars['unique_items'][$key] = $tid;
        }
      }
      break;
    case 'journals':
      $row = !empty($vars["rows"]) ? current($vars["rows"]) : '';
      $nid = (!empty($row) && !empty($row["content"]) &&
        !empty($row["content"]["#row"]->field_journals_files_paragraphs_item_field_data_nid)) ?
        $row["content"]["#row"]->field_journals_files_paragraphs_item_field_data_nid : '';
      if (!empty($nid)) {
        $parent_node = \Drupal\node\Entity\Node::load($nid);

        if ($parent_node->hasField('title')) {
          $title = $parent_node->get('title');
          $title = $title->getValue();
          $vars["title"] = !empty($title) && !empty($title[0]) ? $title[0]['value'] : '';
        }
        if ($parent_node->hasField('field_journals_subtitle')) {
          $subtitle = $parent_node->get('field_journals_subtitle');
          $subtitle = $subtitle->getValue();
          $vars["subtitle"] = !empty($subtitle) && !empty($subtitle[0]) ? $subtitle[0]['value'] : '';
        }
      }
      break;
    case 'senate_staff':
      $rows = !empty($vars["rows"]) ? $vars["rows"] : [];
      $letters = [];
      foreach ($rows as $key => $row) {
        $paragraph = !empty($row["content"]) ? $row["content"]["#paragraph"] : '';
        $name = !empty($paragraph) && $paragraph->hasField('field_staff_name') ?
          $paragraph->get('field_staff_name') : '';
        $name = !empty($name) ? $name->get(0)->value : '';
        $name_arr = explode(' ', $name);
        $name = end($name_arr);

        $letter = substr($name, 0, 1);
        $letter = strtolower($letter);
        $letters[$key] = $letter;
      }
      $vars['letters'] = $letters;
      break;

    case 'issue_papers':
      $row = !empty($vars["rows"]) ? current($vars["rows"]) : '';
      $nid = (!empty($row) && !empty($row["content"]) &&
        !empty($row["content"]["#row"]->nid)) ?
        $row["content"]["#row"]->nid : '';
      if (!empty($nid)) {
        $node = \Drupal\node\Entity\Node::load($nid);
        if ($node->hasField('field_issue_page_type')) {
          $type = $node->get('field_issue_page_type');
          $type = $type->getValue();
          if (!empty($type)) {

          $term_obj = Drupal::entityTypeManager()
            ->getStorage('taxonomy_term')
            ->load($type[0]['target_id']);

            $term_type = $term_obj->getName();
            $vars['wrapper'] = [''];
            switch ($term_type) {
              case "Text":
                $vars['wrapper'][] = 'bTiles bTiles_rel bTiles_rel_b bTiles_gap_a';
                $vars['inner_wrapper'] = new Attribute(['class' => ['bTiles__items']]);
                break;
              case "Links":
              case "Files":
                $vars['wrapper'][] = 'bListItems bListItems_a bListItems_gap_a';
                $vars['inner_wrapper'] = new Attribute(['class' => ['bListItems__items']]);
                break;
            }
          }
        }
      }
      break;
    case 'senators':
      if ($view->current_display == 'block_1'){
        $unique_items = [];
        $rows = !empty($vars["rows"]) ? $vars["rows"] : [];
        foreach ($rows as $key => $row) {
          if (in_array($row['content']['#row']->nid, $unique_items)) {
            unset($vars["rows"][$key]);
          }
          $unique_items[] = $row['content']['#row']->nid;
        }
      }
      break;
  }
}
function senate_preprocess_views_view_fields(&$vars) {

  $fields = $vars['fields'];
  if ($vars['view']->id() == 'senators'){

    $view_obj = $vars['view'];
    $exposed_inp = $view_obj->getExposedInput();
    $exposd_inp_committee = !empty($exposed_inp["committee"]) ? $exposed_inp["committee"] : '';
    $committee_filter_value = Term::load($exposd_inp_committee);

    if (!empty($exposd_inp_committee)) {
      $expsed_committee_chair = '';
      $expsed_committee_vicechair = '';

      if (!empty($committee_filter_value) && is_object($committee_filter_value)) {
        if (isset($committee_filter_value->get('field_committee_chair')->entity)) {
          $committee_chair_value = $committee_filter_value->get('field_committee_chair')
            ->getValue();
          $expsed_committee_chair = reset($committee_chair_value);
        }
        if (isset($committee_filter_value->get('field_committee_vice_chairman')->entity)) {
          $committee_vice_chairman_value = $committee_filter_value->get('field_committee_vice_chairman')
            ->getValue();
          $expsed_committee_vicechair = reset($committee_vice_chairman_value);
        }
      }

      if (!empty($expsed_committee_chair) && !empty($fields['nid']) &&
        ($expsed_committee_chair['target_id'] == $fields['nid']->content)) {
        $vars['post'] = t('Chair');

      }
      if (!empty($expsed_committee_vicechair) && !empty($fields['nid']) &&
        $expsed_committee_vicechair['target_id'] ==  $fields['nid']->content) {
        $vars['post'] = t('Vice Chair');
      }
    }

  }


  if (!empty($fields['field_issue_page_type'])) {

    $type = $fields['field_issue_page_type']->content;
    switch ($type){
      case "Text":
        $vars['type'] = 'text';
        break;
      case "Links":
        $vars['type'] = 'link';
      break;
      case "Files":
      $vars['type'] = 'files';
      break;
    }
  }
}
/**
 * Implements hook_preprocess_views_view();
 */
function senate_preprocess_views_view(&$vars) {
  $view = $vars['view'];
  $id = $view->id();
  $display_id = $view->current_display;

  $vars['socials'] = _senate_get_socials($view, 'view');

  switch ($id) {
    case 'senators':
      $vars['total_rows'] = Markup::create("<h4>Showing " . $view->total_rows ." Senators</h4>");
      $exp_input = $view->getExposedInput();
      $zip_exp_input = !empty($exp_input["zip"]) ? $exp_input["zip"] : '';
      $vars['show_search_address_txt'] = !empty($zip_exp_input) && ($view->total_rows > 1) ? TRUE : FALSE;
      break;
    case 'subcommittee_events':
      $tid = !empty($view->args) ? $view->args[0] : '';
      if (!empty($tid)) {
        $tid = explode(',', $tid);
        $parent = Drupal::entityTypeManager()->getStorage('taxonomy_term')->loadAllParents($tid[0]);
        $term_obj = reset($parent);
        if (!empty($term_obj)) {
          $vars['committee_name'] = Markup::create("<h2>Upcoming " . $term_obj->getName() ." Events</h2>");
          $vars['events_url'] = "/upcoming-events/" . $view->args[0];
        }
      }
      $vars['breadcrumbs'] = _senate_get_block('custombreadcrumbblock');
      $vars['webform'] = _senate_get_block('webform_notification_block');
      break;
    case 'agencies_documents':
      $tid = !empty($view->args) ? $view->args[1] : '';
      if (!empty($tid) && is_numeric($tid)) {
        $term_obj = Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($tid);
        $vars['title'] = $term_obj->getName();
      }
      $vars['breadcrumbs'] = _senate_get_block('custombreadcrumbblock');
      break;
    case 'session_summary':
      $vars['breadcrumbs'] = _senate_get_block('custombreadcrumbblock');
      $archive = _senate_get_session_summary_years();
      $vars['select_year'] = [
        '#theme' => 'senate_session_summary_select',
        '#archive' => $archive,
      ];
      break;
    case 'issue_papers':
      $archive = _senate_get_issue_type_terms();
      $vars['select_issue'] = [
        '#theme' => 'senate_issue_type_select',
        '#archive' => $archive,
      ];

      $vars['breadcrumbs'] = _senate_get_block('custombreadcrumbblock');
      break;

    case 'week_review':
      $archive = _senate_get_archive_week_review();
      $current_path = \Drupal::service('path.current')->getPath();

      $vars['sidebar'] = [
        '#theme' => 'senate_news_sidebar',
        '#archive' => $archive,
        '#current_path' => $current_path,
      ];
      $date = $view->args;
      if (!empty($date) && !empty($date[0])) {
        $date_obj = new DrupalDateTime($date[0]);
        $vars['showing'] = $date_obj->format('F, Y');
      }
      else {
        $vars['showing'] = t('All');
      }
      break;
    case 'press_releases_audio':
    case 'press_releases':
      $is_audio = ($id === 'press_releases_audio');
      $archive = _senate_get_archive_press_releases_review($is_audio);
      $current_path = \Drupal::service('path.current')->getPath();

      $vars['sidebar'] = [
        '#theme' => 'senate_press_release_sidebar',
        '#archive' => $archive,
        '#current_path' => $current_path,
        '#is_audio' => $is_audio
      ];
      $date = $view->args;
      if (!empty($date) && !empty($date[0])) {
        $date_obj = new DrupalDateTime($date[0]);
        $vars['showing'] = $date_obj->format('F, Y');
      }
      else {
        $vars['showing'] = t('All');
      }
      break;
    case 'journals':
    case 'senate_staff':
      $vars['breadcrumbs'] = _senate_get_block('custombreadcrumbblock');
      break;
    case 'calendar_lt_st_journals':
    case 'calendar_lt_joint_app_bd':
      $vars['path_to_theme'] = base_path() . drupal_get_path('theme', 'senate');
      break;
    case 'terms_glossary':
      $vars['breadcrumbs'] = _senate_get_block('custombreadcrumbblock');
      $vars['top_text'] = _senate_get_block('glossarydescription');
      $vars['path_to_theme'] = base_path() . drupal_get_path('theme', 'senate');
      break;
    case 'senate_artwork':
      $vars['breadcrumbs'] = _senate_get_block('custombreadcrumbblock');
      $vars['path_to_theme'] = base_path() . drupal_get_path('theme', 'senate');

      $exp_input = $view->getExposedInput();
      $location = !empty($exp_input["location"]) ? $exp_input["location"] : '';
      if (!empty($location)) {
        $result = !empty($view->result[0]) ? $view->result[0] : '';
        $entity = !empty($result->_entity) ? $result->_entity : '';

        if (!empty($entity)) {
          $caption = $entity->get('field_edu_indiv_art_work_cap')->getValue();
          $caption = !empty($caption[0]) ? $caption[0]["value"] : '';
          $caption_array = preg_split('/<br[^>]*>/i', $caption);
          $caption_array = !empty($caption_array) ? $caption_array : [];
          foreach ($caption_array as $value) {
            if (strpos($value, 'Location') !== FALSE) {
              $value = html_entity_decode($value);
              $value = strip_tags($value);
              $value = str_replace('Location:', '', $value);
              $location = trim($value);
            }
          }
        }

        $vars['top_text'] = $location;
      }
      else {
        $vars['top_text'] = _senate_get_block('senateartworkdescription');
      }
      break;
    case 'senate_votes':
    case 'committees':
      $vars['path_to_theme'] = base_path() . drupal_get_path('theme', 'senate');
      break;
    case 'search_statutes_constitutions':
      $exposed_input = $view->getExposedInput();
      if (!empty($exposed_input)) {
        $query = !empty($exposed_input["constitutions"]) && !empty($exposed_input["op"]) &&
          ($exposed_input["op"] == 'constitutions_submit') ? $exposed_input["constitutions"] : '';
        $vars['query_text'] = empty($query) && !empty($exposed_input["statutes"]) ?
          $exposed_input["statutes"] : $query;
      }
      break;
    case 'senator_press_release':
      $args = !empty($view->args) ? $view->args : [];
      $senator_name = !empty($args[0]) ? $args[0] : '';
      $nid = $senator_name;
      $date = !empty($args[1]) ? $args[1] : '';
      if (!empty($senator_name) && !is_numeric($senator_name)) {
        $nid = CustomNidToAuthor::convertSenatorNameToNid($senator_name);
      }

      if (!empty($nid) && is_numeric($nid)) {
        $node_storage = \Drupal::entityTypeManager()->getStorage('node');
        $node = $node_storage->load($nid);
        $name = !empty($node) ? $node->get('title')->value : '';
        $vars['title'] = t("Sen. @name’s Press Releases", [
          '@name' => $name,
        ]);

        $archive = _senate_get_archive_press_releases_review(FALSE, $nid);
        $current_path = \Drupal::service('path.current')->getPath();

        $vars['sidebar'] = [
          '#theme' => 'senate_press_release_sidebar',
          '#archive' => $archive,
          '#current_path' => $current_path,
          '#is_audio' => FALSE,
          '#senator_nid' => $senator_name,
        ];
      }

      if (!empty($date)) {
        $date_obj = new DrupalDateTime($date);
        $vars['showing'] = $date_obj->format('F, Y');
      }
      else {
        $vars['showing'] = t('All');
      }
      $vars['breadcrumbs'] = _senate_get_block('custombreadcrumbblock');
      break;
    case 'senator_recent_news':
      $vars['news_url'] = SENATE_SENATOR_RECENT_NEWS_URL . "/" . $view->args[0];
      break;
    case 'senator_rec_news_land':
      $args = !empty($view->args) ? $view->args : [];
      $senator_id = !empty($args[0]) ? $args[0] : '';
      $archive = _senate_get_archive_senator_blog_post($senator_id);
      $current_path = \Drupal::service('path.current')->getPath();

      $vars['sidebar'] = [
        '#theme' => 'senator_blog_post_sidebar',
        '#archive' => $archive,
        '#current_path' => $current_path,
        '#base_path' => SENATE_SENATOR_RECENT_NEWS_URL . "/" . $senator_id,
      ];
      $date = !empty($args[1]) ? $args[1] : '';
      if (!empty($date)) {
        $date_obj = new DrupalDateTime($date);
        $vars['showing'] = $date_obj->format('F, Y');
      }
      else {
        $vars['showing'] = t('All');
      }
      break;
  }
}

/**
 * Implements hook_preprocess_paragraph().
 */
function senate_preprocess_paragraph(array &$vars) {
  $paragraph = $vars['paragraph'];
  $bundle = $paragraph->bundle();

  switch ($bundle) {
    case 'publications':
      $node = \Drupal::routeMatch()->getParameter('node');
      if (!empty($node) && is_object($node) && $node->id() == SENATE_CONTACTS_LANDING_NID) {
        $vars['icon_attributes'] = ' bTiles__ico_a';
      }

      $link = !empty($vars["content"]["field_par_publications_page_link"]) &&
        !empty($vars["content"]["field_par_publications_page_link"]["#items"]) ?
        $vars["content"]["field_par_publications_page_link"]["#items"]->getValue() : '';
      $link_att = !empty($link) && !empty($link[0]["options"]) ? $link[0]["options"]["attributes"] : [];
      $link_att['class'] = ['bTiles__item'];
      $vars['link_attr'] = new Attribute($link_att);
      break;
    case 'journals_files':
      $date = (!empty($vars["content"]["field_journals_files_date"]) &&
        !empty($vars["content"]["field_journals_files_date"]['#items'])) ?
        $vars["content"]["field_journals_files_date"]['#items']->getValue() : '';
      $file = (!empty($vars["content"]["field_journals_files_file"]) &&
        !empty($vars["content"]["field_journals_files_file"][0])) ?
        $vars["content"]["field_journals_files_file"][0]['#file'] : '';

      $date = !empty($date) && !empty($date[0]) ? $date[0]["value"] : '';
      $vars['file_url'] = !empty($file) ? file_create_url($file->getFileUri()) : '';
      $date_obj = new DrupalDateTime($date);
      $vars['date'] = $date_obj->format('F j');

      if ($vars["view_mode"] == 'calendar_landing') {
        $vars['date'] = $date_obj->format('F j, Y');
      }
      break;
    case 'staff':
      $email = (!empty($vars["content"]["field_staff_email"]) &&
        !empty($vars["content"]["field_staff_email"]['#items'])) ?
        $vars["content"]["field_staff_email"]['#items']->getValue() : '';
      $vars['email'] = !empty($email) && !empty($email[0]) ? $email[0]["value"] : '';
      break;
    case 'video':
    case 'gallery_video':
      if (!empty($vars['content']['field_video_video']) &&
        !empty($vars['content']['field_video_video']['#items'])) {
        $items = $vars['content']['field_video_video']['#items'];
        $value = !empty($items) ? $items->getValue() : '';
        if (!empty($value)) {
          $url = $value[0]['value'];
          $video_data = _get_youtube_embed_data($url, ['rel' => 0, 'controls' => 0, 'showinfo' => 0, 'enablejsapi' => 1]);
          $vars['video_id'] = !empty($video_data['video_id']) ? $video_data['video_id'] : '';
          $vars['video_url'] = !empty($video_data['url']) ? $video_data['url'] : '';
        }
      }
      break;
    case 'gallery_image':
      if (!empty($vars['content']['field_gallery_par_image'][0]['#item'])){
        $gallery_img_uri = $vars['content']['field_gallery_par_image'][0]['#item']->entity->url();
      }
      $vars['gallery_img_uri'] = !empty($gallery_img_uri) ? $gallery_img_uri : '';
      $vars['gallery_img_download_target'] = !empty($vars['gallery_img_uri']) ? end(explode('/',$vars['gallery_img_uri'])) : '';

      break;
    case 'senate_votes':
      $measure = (!empty($vars["content"]["field_senate_votes_measure"]) &&
        !empty($vars["content"]["field_senate_votes_measure"]['#items'])) ?
        $vars["content"]["field_senate_votes_measure"]['#items']->getValue() : '';
      $measure_link = (!empty($vars["content"]["field_senate_votes_measure_link"]) &&
        !empty($vars["content"]["field_senate_votes_measure_link"]['#items'])) ?
        $vars["content"]["field_senate_votes_measure_link"]['#items']->getValue() : '';

      $author = (!empty($vars["content"]["field_senate_votes_author"]) &&
        !empty($vars["content"]["field_senate_votes_author"]['#items'])) ?
        $vars["content"]["field_senate_votes_author"]['#items']->getValue() : '';
      $author_link = (!empty($vars["content"]["field_senate_votes_author_link"]) &&
        !empty($vars["content"]["field_senate_votes_author_link"]['#items'])) ?
        $vars["content"]["field_senate_votes_author_link"]['#items']->getValue() : '';

      $vars["measure"] = !empty($measure) && !empty($measure[0]) ? $measure[0]["value"] : '';
      $measure_link = !empty($measure_link) && !empty($measure_link[0]) ? $measure_link[0]["uri"] : '';

      $vars["author"] = !empty($author) && !empty($author[0]) ? $author[0]["value"] : '';
      $author_link = !empty($author_link) && !empty($author_link[0]) ? $author_link[0]["uri"] : '';

      if (!empty($vars["measure"]) && !empty($measure_link)) {
        $url = Url::fromUri($measure_link);

        $attributes['target'] = '_blank';
        $url->setOption('attributes', $attributes);
        $vars["measure"] = Link::fromTextAndUrl($vars["measure"], $url);
      }

      if (!empty($vars["author"]) && !empty($author_link)) {
        $url = Url::fromUri($author_link);
        $vars["author"] = Link::fromTextAndUrl($vars["author"], $url);
      }
      break;
  }
}

/**
 * Years of existing nodes.
 * @param $tid
 *
 * @return array
 */
function _senate_get_years_existing_nodes($tid) {
  if (empty($tid)) {
    return [];
  }

  $query = \Drupal::database()->select('node_field_data', 'nfd')
    ->condition('nfd.type', 'agencies_doc')
    ->condition('nfd.status', 1);
  $query->innerJoin('node__field_agencies_doc_agency', 'ag', 'ag.entity_id = nfd.nid and ag.deleted = 0');
  $query->innerJoin('node__field_agencies_doc_year', 'year', 'year.entity_id = nfd.nid and year.deleted = 0');
  $query->fields('year', ['field_agencies_doc_year_value'])
    ->condition('ag.field_agencies_doc_agency_target_id', $tid);
  $query->distinct(TRUE);
  $result = $query->execute()->fetchCol();

  return !empty($result) ? $result : [];
}


function _get_youtube_embed_data($url, $query_options = array()) {
  $vars = [];
  parse_str(parse_url($url, PHP_URL_QUERY), $parts);

  if (isset($parts['v'])) {
    $vars['video_id'] = Html::escape($parts['v']);
    $embed_path = '/embed/' . $vars['video_id'];
  }
  elseif (isset($parts['l'])) {
    $vars['video_id'] = Html::escape($parts['l']);
    $embed_path = '/embed/videoseries';
  }
  if (!empty($embed_path)) {
    $url = Url::fromUri('https://www.youtube.com'  . $embed_path, ['query' => $query_options, 'external' => TRUE]);
    $vars['url'] = $url->toString();
  }

  return $vars;
}

function _senate_get_committee_options($committee_options) {
  if (!empty($committee_options["All"])) {
    $new_options['All'] = t('Select Committee');
  }

  $new_options['Standing Committees'] = [];
  $new_options['Subcommittees'] = [];

  $tree = \Drupal::entityTypeManager()->getStorage('taxonomy_term')
    ->loadTree('committees', 0, NULL, FALSE);
  $first_level_tids = [];
  $second_level_tids = [];
  foreach ($tree as $term) {
    $parent = (!empty($term->parents) && isset($term->parents[0])) ? $term->parents[0] : '';
    if ($parent === '0') {
      $first_level_tids[] = $term->tid;
    }
    else {
      $second_level_tids[] = $term->tid;
    }
  }

  foreach ($committee_options as $tid => $name) {
    if (in_array($tid, $first_level_tids)) {
      $new_options['Standing Committees'][$tid] = $name;
    }
    elseif (in_array($tid, $second_level_tids)) {
      $new_options['Subcommittees'][$tid] = $name;
    }
  }

  return $new_options;
}

