function _events_custom_get_events() {
  $date = date("Ymd", strtotime('monday this week'));
//  $date = '20191213';
  //$response = \Drupal::state()->get('events_custom.cache');
  if(empty($response)) {
    //dsm('not from cache');
    $response = (string) \Drupal::httpClient()
      ->get('https://sg001-harmony.sliq.net/00282/Harmony/en/api/Data/GetContentEntityByWeek/' . $date . '/-1', ['timeout' => 0, 'headers' => [],])
      ->getBody();

    //\Drupal::state()->set('events_custom.cache', $response);
  }

  $events =  json_decode($response);

  $rooms = [
    '/230/' => ['url' => '/room-230', 'title' => 'room 230', 'room_nid' => 7413],
    '/419.*b/' => ['url' => '/room-419-b', 'title' => 'room 419-b', 'room_nid' => 7416],
    '/419.*c/' => ['url' => '/room-419-c', 'title' => 'room 419-c', 'room_nid' => 7417],
    '/419/' => ['url' => '/room-419', 'title' => 'room 419', 'room_nid' => 7414],
    '/511.*a/' => ['url' => '/room-511a', 'title' => 'room 511a', 'room_nid' => 10507],
    '/535/' => ['url' => '/room-535', 'title' => 'room 535', 'room_nid' => 10508],
  ];

  if(!empty($events)) {
    foreach ($events as &$event) {
      //falback value
      $event->location_url = '/audio-video';
      $event->location_title = 'view';
      if(!empty($event->Location)) {
        $loc = strtolower($event->Location);
        foreach ($rooms as $pattern => $room_info) {
          if(preg_match($pattern, $loc)) {
            $event->location_url = $room_info['url'];
            $event->location_title = $room_info['title'];
            $event->location_room = $room_info['room_nid'];
            break;
          }
        }
      }
    }
  }

  return $events;
}

/**
 * Implements hook_cron().
 */
function events_custom_cron() {
  $cron_config = \Drupal::configFactory()->getEditable('events_custom.settings');
  $interval = $cron_config->get('interval');
  $interval = !empty($interval) ? $interval : 3600;
  $request_time = \Drupal::time()->getRequestTime();

  $next_execution = \Drupal::state()->get('events_custom.next_execution', 0);

  if ($request_time >= $next_execution) {
    \Drupal::logger('events_custom')->notice('events_custom ran');
    if (\Drupal::state()->get('events_custom_show_status_message')) {
      \Drupal::messenger()->addMessage(t('events_custom executed at %time', ['%time' => date('c')]));
      \Drupal::state()->set('events_custom_show_status_message', FALSE);
    }

    $prev_execution = \Drupal::state()->get('events_custom.prev_execution', 0);
    $update_all = \Drupal::state()->get('events_custom.update_all', FALSE);
    \Drupal::state()->set('events_custom.next_execution', $request_time + $interval);
    \Drupal::state()->set('events_custom.prev_execution', $request_time);
    \Drupal::state()->set('events_custom.update_all', FALSE);
    $type = empty($prev_execution) ? 'all' : 'month';

    $queue = \Drupal::queue('events_custom');
    $item = (object) ['type' => $type, 'update_all' => $update_all];

    $queue->createItem($item);
  }
}


/**
 * Implements hook_preprocess_node().
 */
function events_custom_preprocess_node(array &$vars) {
  global $base_path;
  $node = $vars['node'];
  $view_mode = !empty($vars["view_mode"]) ? $vars["view_mode"] : '';

  if (!empty($node) && is_object($node)) {

    switch ($node->bundle()) {
      case 'committee_events':
        $timetable = _events_custom_get_events_timetable();

        $vars['#attached']['library'][] = 'events_custom/events_timetable';
        $vars['#attached']['drupalSettings']['events_custom']['timetable'] = $timetable;
        break;
    }
  }
}

/**
 * Implements hook_preprocess_views_view();
 */
function events_custom_preprocess_views_view(&$vars) {
  $view = $vars['view'];
  $id = $view->id();
  $display_id = $view->current_display;

  switch ($id) {
    case 'committee_events':
      $timetable = _events_custom_get_events_timetable();

      $vars['#attached']['library'][] = 'events_custom/events_timetable';
      $vars['#attached']['drupalSettings']['events_custom']['timetable'] = $timetable;
      break;
  }
}

function _events_custom_get_events_timetable() {
  $query = \Drupal::database()->select('node_field_data', 'nfd')
    ->condition('nfd.type', 'committee_events')
    ->condition('nfd.status', 1);
  $query->innerJoin('node__field_comt_evt_date', 'start_date', 'start_date.entity_id = nfd.nid AND start_date.deleted = 0 AND start_date.bundle = \'committee_events\'');
  $query->innerJoin('node__field_comt_evt_to_date', 'end_date', 'end_date.entity_id = nfd.nid AND end_date.deleted = 0 AND end_date.bundle = \'committee_events\'');
  $query->innerJoin('node__field_comt_evt_src_id', 'src_id', 'src_id.entity_id = nfd.nid AND src_id.deleted = 0 AND src_id.bundle = \'committee_events\'');

  $query->leftJoin('node__field_comt_evt_time', 'time_txt', 'time_txt.entity_id = nfd.nid AND time_txt.deleted = 0 AND time_txt.bundle = \'committee_events\'');

  $query->fields('nfd', ['nid']);
  $query->fields('start_date', ['field_comt_evt_date_value']);
  $query->fields('end_date', ['field_comt_evt_to_date_value']);
  $query->fields('src_id', ['field_comt_evt_src_id_value']);

  $query->isNull('time_txt.field_comt_evt_time_value');

  $query->orderBy('start_date.field_comt_evt_date_value', 'ASC');

//  $a = $query->__toString();

  $result = $query->execute()
    ->fetchAll();
  $result = !empty($result) ? $result : [];

  $timetable = _events_custom_get_events_timetable_normalize($result);

  return $timetable;
}

function _events_custom_get_events_timetable_normalize($result = []) {
  $timetable = [];
  $timezone_db = DateTimeItemInterface::STORAGE_TIMEZONE;
  $utc_timezone = new DateTimeZone('UTC');

  foreach ($result as $key => $value) {
    $nid = !empty($value->nid) ? $value->nid : '';
    $start = !empty($value->field_comt_evt_date_value) ? $value->field_comt_evt_date_value : '';
    $end = !empty($value->field_comt_evt_to_date_value) ? $value->field_comt_evt_to_date_value : '';
    $meetingId = !empty($value->field_comt_evt_src_id_value) ? $value->field_comt_evt_src_id_value : '';

    if (!empty($start)) {
      $start_date_obj = new DrupalDateTime($start, $timezone_db);
      $start_date_obj->setTimezone($utc_timezone);
      $start = $start_date_obj->format('Y-m-d H:i:s');
    }
    if (!empty($end)) {
      $end_date_obj = new DrupalDateTime($end, $timezone_db);
      $end_date_obj->setTimezone($utc_timezone);
      $end = $end_date_obj->format('Y-m-d H:i:s');
    }

    $timetable[] = [
      'nid' => $nid,
      'startUtc' => $start,
      'endUtc' => $end,
      'meetingId' => $meetingId,
    ];
  }

  return $timetable;
}
