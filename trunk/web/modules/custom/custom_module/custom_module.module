<?php
/**
 * @file
 * Custom module.
 */

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Ajax\AjaxResponse;
use Drupal\Core\Ajax\ReplaceCommand;
/**
 * Implements hook_form_alter().
 *
 * @param $form
 * @param \Drupal\Core\Form\FormStateInterface $form_state
 * @param $form_id
 */
function custom_module_form_alter(&$form, FormStateInterface &$form_state, $form_id) {
  if (preg_match('/webform_submission_subcommittee_notifications/', $form_id)) {
    $view_id = Drupal::routeMatch()->getParameter('view_id');

    if (!empty($view_id)) {
      switch ($view_id) {
        case 'subcommittee_events':
          $current_path = \Drupal::service('path.current')->getPath();
          $arg  = explode('/', $current_path);
          if (!empty($arg[2]) && is_numeric($arg[2])) {
            $form['actions']['submit']['#validate'][] = 'custom_module_add_committee';
          }
          break;
      }
    }
  }
  switch ($form_id){
    case 'webform_submission_contact_senator_node_3945_add_form':
      $ajax = [
        'callback' => 'custom_module_contact_form_ajax_callback',
        'event' => 'change',
        'effect' => 'fade',
      ];
      $senator_nid = \Drupal::request()->query->get('sid');
      $form["elements"]["select_your_senator"]['#ajax'] = $ajax;
      $form["elements"]["mail_to"]['#ajax'] = $ajax;
      $form["elements"]["mail_to"]['#attributes'] = array('id' => 'mail-to-ajax-wrapper');
      $form['elements']['mail_to']['#access'] = FALSE;

      $values = $form_state->getValues();
      $email = "change@default.email";

      if (!empty($senator_nid)){
        $node = \Drupal\node\Entity\Node::load($senator_nid);
        if (!empty($node) && ($node->getType() == 'senator')){
          if ($node->get('field_senator_contact_email')->getValue()){
            $email = $node->get('field_senator_contact_email')->getValue();
            $email = array_shift($email)['value'];
          }
          $form['elements']['select_your_senator']['#default_value'] = $senator_nid;
          $form['elements']['select_your_senator']['#access'] = FALSE;
          $form['elements']['mail_to']['#default_value'] = $email;

        }
      }
      if(!empty($values) ) {
        $node = \Drupal\node\Entity\Node::load($values['select_your_senator']);
        if (!empty($node) && ($node->getType() == 'senator')){
          if ($node->get('field_senator_contact_email')->getValue()){
            $email = $node->get('field_senator_contact_email')->getValue();
            $email = array_shift($email)['value'];
          }
          $form['elements']['mail_to']['#default_value'] = $email;

        }
      }
      break;
  }

}

function custom_module_add_committee($form, FormStateInterface $form_state) {
  $view_id = Drupal::routeMatch()->getParameter('view_id');

  if (!empty($view_id)) {
    switch ($view_id) {
      case 'subcommittee_events':
        $current_path = \Drupal::service('path.current')->getPath();
        $arg  = explode('/', $current_path);
        if (!empty($arg[2]) && is_numeric($arg[2])) {
          $form_state->setValue('committee', $arg[2]);
        }
        break;
    }
  }
}

/**
 * Implements hook_views_query_alter().
 */
function custom_module_views_query_alter(\Drupal\views\ViewExecutable $view,
                                                   \Drupal\views\Plugin\views\query\Sql $query) {

  if ($view->id() == 'week_review' && $view->getDisplay()->display['id'] == 'page_1') {
    foreach ($query->where as $key => &$condition_group) {
      foreach ($condition_group['conditions'] as &$condition) {
        if (strpos($condition['field'], 'DATE_FORMAT(node__field_week_review_date.field_week_review_date_value') !== FALSE) {
          $condition['field'] = str_replace('%Y-%m-%d', '%Y-%m', $condition['field']);
        }
      }
    }
  }
  if ($view->id() == 'press_releases' && $view->getDisplay()->display['id'] == 'page_1') {
    foreach ($query->where as $key => &$condition_group) {
      foreach ($condition_group['conditions'] as &$condition) {
        if (strpos($condition['field'], 'DATE_FORMAT((node__field_date.field_date_value') !== FALSE) {
          $condition['field'] = str_replace('%Y-%m-%d', '%Y-%m', $condition['field']);
        }
      }
    }
  }
  if ($view->id() == 'journals' && $view->getDisplay()->display['id'] == 'page_1') {
    $table_files = $query->getTableInfo('node__field_journals_files');
    $table_files['join']->field = 'field_journals_files_target_id';
    $table_files["join"]->configuration["field"] = 'field_journals_files_target_id';

    $table_node = $query->getTableInfo('field_journals_files_paragraphs_item_field_data');
    $table_node['join']->field = 'nid';
    $table_node["join"]->configuration["field"] = 'nid';

    foreach ($query->where as $key => &$condition_group) {
      foreach ($condition_group['conditions'] as &$condition) {
        if (strpos($condition['field'], 'DATE_FORMAT(paragraph__field_journals_files_date.field_journals_files_date_value') !== FALSE) {
          $condition['field'] = str_replace('%Y-%m-%d', '%Y-%m', $condition['field']);
        }
      }
    }
  }
  if ($view->id() == 'calendar_lt_st_journals' && $view->getDisplay()->display['id'] == 'block_1') {
    $table_files = $query->getTableInfo('node__field_journals_files');
    $table_files['join']->field = 'field_journals_files_target_id';
    $table_files["join"]->configuration["field"] = 'field_journals_files_target_id';

    $table_node = $query->getTableInfo('field_journals_files_paragraphs_item_field_data');
    $table_node['join']->field = 'nid';
    $table_node["join"]->configuration["field"] = 'nid';
  }
  if ($view->id() == 'calendar_lt_joint_app_bd' && $view->getDisplay()->display['id'] == 'block_1') {
    $table_files = $query->getTableInfo('node__field_cl_app_bud_calendar');
    $table_files['join']->field = 'field_cl_app_bud_calendar_target_id';
    $table_files["join"]->configuration["field"] = 'field_cl_app_bud_calendar_target_id';

    $table_node = $query->getTableInfo('field_cl_app_bud_calendar_paragraphs_item_field_data');
    $table_node['join']->field = 'nid';
    $table_node["join"]->configuration["field"] = 'nid';
  }
  if ($view->id() == 'search_statutes_constitutions' && $view->getDisplay()->display['id'] == 'page_1') {
    $configuration = [
      'type'       => 'LEFT',
      'table'      => 'search_index',
      'field'      => 'sid',
      'left_table' => 'file_managed',
      'left_field' => 'fid',
      'operator'   => '=',
      'extra' => [
        0 => [
          'field' => 'type',
          'value' => 'file_search',
        ],
      ],
    ];

    $join = \Drupal\views\Views::pluginManager('join')
      ->createInstance('standard', $configuration);
    $rel = $query->addRelationship('search', $join, 'file_managed');
    $query->addTable('search_index', $rel, $join, 'search_index');

    foreach ($query->where as $key => &$condition_group) {
      foreach ($condition_group['conditions'] as &$condition) {
        $field_str = is_object($condition['field']) ? $condition['field']->conditions() : '';
        if (!empty($field_str) && strpos($field_str[0]['field'], 'file_managed') !== FALSE) {
          $condition['field']->condition('search.word', $field_str[0]["value"], $field_str[0]["operator"]);
        }
      }
    }

    $exposed_input = $view->getExposedInput();
    if (!empty($exposed_input)) {
      $type = !empty($exposed_input["constitutions"]) && !empty($exposed_input["op"]) &&
        ($exposed_input["op"] == 'constitutions_submit') ? 'constitutions' : '';
      $type = empty($type) && !empty($exposed_input["statutes"]) ? 'statutes' : $type;

      if (!empty($type)) {
        $configuration = [
          'type'       => 'LEFT',
          'table'      => 'node__field_statutes_constit_type',
          'field'      => 'entity_id',
          'left_table' => 'field_statutes_constit_files_file_managed',
          'left_field' => 'nid',
          'operator'   => '=',
          'extra' => [
            0 => [
              'field' => 'bundle',
              'value' => 'statutes_constit',
            ],
          ],
        ];

        $join = \Drupal\views\Views::pluginManager('join')
          ->createInstance('standard', $configuration);
        $rel = $query->addRelationship('constit_type', $join, 'field_statutes_constit_files_file_managed');
        $query->addTable('node__field_statutes_constit_type', $rel, $join, 'constit');

        $query->addWhere('', 'constit_type.field_statutes_constit_type_value', $type, '=');

        //      $a = $query->query()->__toString();
      }
    }
  }
}

/**
 * Register form ajax callback -  for validate classes
 *
 * @param $form
 * @param $form_state
 * @return mixed
 */
function custom_module_contact_form_ajax_callback($form, &$form_state) {
  $response = new AjaxResponse();
  $response->addCommand(new ReplaceCommand('#mail-to-ajax-wrapper',$form["elements"]["mail_to"]["mail_to_ajax_wrapper"]));

  return $response;
}
