    '82' => '20012d927a',
    '69' => '03df5d06c3',
    '70' => '2b1109ecd9',
    '71' => '88edf99954',
    '72' => 'f7ac316d53',
    '73' => '4e3ee65d72',
    '74' => '49b253570a',
    '75' => 'd30c6731fa',
    '76' => '1bfbd589f7',
    '77' => '884f58114c',
    '78' => '9a23cdd8d1',
