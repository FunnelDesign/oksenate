}

/**
 * Implements hook_views_data_alter().
 */
function custom_module_views_data_alter(array &$data) {
  if (isset($data['node__field_senator'])) {
    // Create a new views argument
    $data['node__field_senator']['custom_nid_author'] = [
      'title' => t('Custom: Senator nid to Senator node author'),
      'group' => t('Custom'),
      'title short' => t('Nid to Author'),
      'argument' => [
        'table' => 'node__field_senator',
        'field' => 'field_senator_target_id',
        'id' => 'custom_senator_nid_author',
        'zero is null' => TRUE,
      ],
    ];
  }
}

/**
 * Implements hook_page_attachments_alter().
 */
function custom_module_page_attachments_alter(array &$page) {
  global $base_url;
  $html_head = !empty($page['#attached']['html_head']) ? $page['#attached']['html_head'] : [];
  $theme_path = $base_url . '/' . drupal_get_path('theme', 'senate');
  $has_og_image = FALSE;
  $has_tw_image = FALSE;

  foreach ($html_head as $key => $head) {
    $tag = !empty($head[1]) ? $head[1] : '';
    $tag_number = str_replace('og_image_', '', $tag);
    $tag_number = str_replace('twitter_cards_image_', '', $tag_number);

    if (($tag == 'og_image') || ((strpos($tag, 'og_image') !== FALSE) && is_numeric($tag_number))) {
      $attributes = !empty($head[0]["#attributes"]) ? $head[0]["#attributes"] : [];
      $attr_name = !empty($attributes["property"]) ? $attributes["property"] : '';

      if ($attr_name == 'og:image') {
        $has_og_image = TRUE;
      }
    }
    elseif (($tag == 'twitter_cards_image') || ((strpos($tag, 'twitter_cards_image') !== FALSE) && is_numeric($tag_number))) {
      $attributes = !empty($head[0]["#attributes"]) ? $head[0]["#attributes"] : [];
      $attr_name = !empty($attributes["name"]) ? $attributes["name"] : '';

      if ($attr_name == 'twitter:image') {
        $has_tw_image = TRUE;
      }
    }

    if ($head[1] == 'system_meta_generator') {
      unset($page['#attached']['html_head'][$key]);
    }
  }

  if (!$has_og_image) {
    $og_image = [
      '#tag' => 'meta',
      '#attributes' => [
        'property' => 'og:image',
        'content' => $theme_path . '/dist/images/senate-share-photo-generic.jpg',
      ],
    ];
    $page['#attached']['html_head'][] = [$og_image, 'custom_module_og'];
  }

  if (!$has_tw_image) {
    $tw_image = [
      '#tag' => 'meta',
      '#attributes' => [
        'name' => 'twitter:image',
        'content' => $theme_path . '/dist/images/senate-share-photo-generic.jpg',
      ],
    ];
    $page['#attached']['html_head'][] = [$tw_image, 'custom_module_tw'];
  }
}
